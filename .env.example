# --- DATABASE (Local PostgreSQL / Neon PostgreSQL / H2 fallback) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lawtrack
DB_USER=lawtrack_user
DB_PASSWORD=lawtrack_pass

# --- SPRING BOOT CONFIG ---
SPRING_PROFILES_ACTIVE=local
PORT=8080
FRONTEND_URL=http://localhost:3000

# --- SECURITY / API ACCESS ---
# Опциональный токен для авторизации администратора. Если задан, то все запросы должны содержать заголовок X-Admin-Token
ADMIN_TOKEN=your_secure_admin_token_here

# --- TELEGRAM BOT (@BotFather) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- FRONTEND (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ADMIN_TOKEN=your_secure_admin_token_here
