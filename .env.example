# --- SPRING BOOT CONFIG ---
PORT=8080
SPRING_PROFILES_ACTIVE=local
FRONTEND_URL=http://localhost:3000

# --- DATABASE CONNECTION (Single-line DATABASE_URL) ---
# Локальный Postgres: postgresql://lawtrack_user:lawtrack_pass@localhost:5432/lawtrack
# Neon.tech Postgres: postgresql://neondb_owner:password@ep-cool-cloud-12345.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://lawtrack_user:lawtrack_pass@localhost:5432/lawtrack

# --- SECURITY / API ACCESS ---
# Опциональный токен авторизации для защиты API (передается в заголовке X-Admin-Token)
ADMIN_TOKEN=your_secure_admin_token_here

# --- TELEGRAM BOT (@BotFather) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- FRONTEND (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_ADMIN_TOKEN=your_secure_admin_token_here
